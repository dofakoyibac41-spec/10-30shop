# ─── Backend Environment Template ────────────────────────────────────────────
# 10:30 AM Shop — backend/.env.example
# Скопируй этот файл: cp .env.example .env
# Заполни все значения перед запуском

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001

# ─── Admin Credentials ───────────────────────────────────────────────────────
# Логин и пароль для доступа к /admin
ADMIN_LOGIN=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Секрет для подписи JWT токенов. Используй случайную строку 32+ символов.
# Генерация: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_STRING

# ─── Environment ─────────────────────────────────────────────────────────────
# development | production
NODE_ENV=development
